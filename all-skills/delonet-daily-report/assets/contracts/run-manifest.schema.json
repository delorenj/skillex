{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "$id": "https://delonet.local/ddr/run-manifest.schema.json", "title": "RunManifest", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "run_id", "report_date", "started_at", "completed_at", "sections"],
  "properties": {
    "schema_version": {"const": 1}, "run_id": {"type": "string", "minLength": 1}, "report_date": {"type": "string", "format": "date"}, "started_at": {"type": "string", "format": "date-time"}, "completed_at": {"type": "string", "format": "date-time"},
    "sections": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["id", "status", "path"], "properties": {"id": {"type": "string", "minLength": 1}, "status": {"enum": ["complete", "partial", "missing", "invalid", "stale", "failed"]}, "path": {"oneOf": [{"type": "string", "minLength": 1}, {"type": "null"}]}, "reason": {"type": "string", "minLength": 1}}}}
  }
}
